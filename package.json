{
  "name": "@philiprehberger/retry-kit",
  "version": "0.3.0",
  "description": "Async retry with exponential backoff, circuit breaker, and abort signals",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test"
  },
  "devDependencies": {
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  },
  "keywords": [
    "retry",
    "backoff",
    "circuit-breaker",
    "async",
    "resilience",
    "fault-tolerance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-retry-kit.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-retry-kit#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-retry-kit/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
